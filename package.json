{
  "name": "sworld",
  "private": false,
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.34.3"
  },
  "scripts": {
    "build": "turbo run build",
    "build-watch": "turbo run build-watch",
    "clean": "turbo run clean",
    "dev": "turbo run dev --no-cache --parallel --continue",
    "dev:listen": "cp .env.development.local apps/listen/.env.development.local && turbo watch 'dev' --filter=listen",
    "dev:game": "cp .env.development.local apps/game/.env.development.local && turbo watch 'dev' --filter=game",
    "dev:main": "cp .env.development.local apps/main/.env.development.local && turbo watch 'dev' --filter=main",
    "dev:watch": "cp .env.development.local apps/watch/.env.development.local && turbo watch 'dev' --filter=watch",
    "dev:til": "cp .env.development.local apps/til/.env.development.local && turbo watch 'dev' --filter=til",
    "dev:docs": "turbo watch 'dev' --filter=docs",
    "dev:extension": "turbo watch 'dev' --filter=extension",
    "typecheck:main": "tsc -p apps/main/tsconfig.json --noEmit",
    "format": "biome format --write",
    "prepare": "husky",
    "lint": "biome check .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck --filter=!docs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@changesets/cli": "^2.29.7",
    "@types/chrome": "^0.0.268",
    "husky": "^9.1.7",
    "turbo": "2.9.14",
    "typescript": "^5.6.2"
  },
  "packageManager": "pnpm@10.34.3",
  "pnpm": {
    "overrides": {
      "form-data@>=4.0.0 <4.0.4": "4.0.4",
      "shell-quote@<1.8.4": "1.8.4",
      "preact@>=10.26.5 <10.26.10": "10.26.10"
    }
  }
}
