{
  "name": "sworld",
  "private": false,
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.34.3"
  },
  "scripts": {
    "build": "turbo run build",
    "build-watch": "turbo run build-watch",
    "clean": "turbo run clean",
    "dev": "turbo run dev --no-cache --parallel --continue",
    "dev:listen": "cp .env.development.local apps/listen/.env.development.local && turbo watch 'dev' --filter=listen",
    "dev:game": "cp .env.development.local apps/game/.env.development.local && turbo watch 'dev' --filter=game",
    "dev:main": "cp .env.development.local apps/main/.env.development.local && turbo watch 'dev' --filter=main",
    "dev:watch": "cp .env.development.local apps/watch/.env.development.local && turbo watch 'dev' --filter=watch",
    "dev:til": "cp .env.development.local apps/til/.env.development.local && turbo watch 'dev' --filter=til",
    "dev:docs": "turbo watch 'dev' --filter=docs",
    "dev:extension": "turbo watch 'dev' --filter=extension",
    "typecheck:main": "tsc -p apps/main/tsconfig.json --noEmit",
    "format": "biome format --write",
    "prepare": "husky",
    "lint": "biome check .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck --filter=!docs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@changesets/cli": "^2.29.7",
    "@types/chrome": "^0.0.268",
    "husky": "^9.1.7",
    "turbo": "2.9.14",
    "typescript": "^5.6.2"
  },
  "packageManager": "pnpm@10.34.3",
  "pnpm": {
    "overrides": {
      "form-data@>=4.0.0 <4.0.6": "4.0.6",
      "shell-quote@<=1.8.4": "1.9.0",
      "preact@>=10.26.5 <10.26.10": "10.26.10",
      "@testing-library/dom": "10.4.0",
      "@babel/plugin-transform-modules-systemjs@>=7.12.0 <7.29.4": "7.29.7",
      "ajv@>=6.0.0 <6.14.0": "6.15.0",
      "axios@>=1.0.0 <1.18.0": "1.18.0",
      "body-parser@<1.20.6": "1.20.6",
      "brace-expansion@>=1.0.0 <1.1.16": "1.1.16",
      "brace-expansion@>=2.0.0 <2.1.2": "2.1.2",
      "convict@<=6.2.4": "6.2.5",
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "estree-util-value-to-estree@<3.3.3": "3.3.3",
      "follow-redirects@<=1.15.11": "1.16.0",
      "http-proxy-middleware@>=0.16.0 <2.0.10": "2.0.10",
      "immutable@<3.8.3": "3.8.3",
      "joi@<17.13.4": "17.13.4",
      "js-yaml@>=3.0.0 <3.15.0": "3.15.0",
      "js-yaml@>=4.0.0 <4.3.0": "4.3.0",
      "launch-editor@<=2.14.0": "2.14.1",
      "lodash@>=4.0.0 <=4.17.23": "4.18.1",
      "markdown-it@<=14.1.1": "14.2.0",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": "13.2.1",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "path-to-regexp@<0.1.13": "0.1.13",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "rollup@>=2.0.0 <2.80.0": "2.80.0",
      "serialize-javascript@>=6.0.0 <7.0.7": "7.0.7",
      "svgo@>=3.0.0 <3.3.3": "3.3.3",
      "tmp@>=0.0.0 <0.2.7": "0.2.7",
      "webpack@>=5.49.0 <=5.104.0": "5.104.1",
      "webpack-dev-server@<=5.2.5": "5.2.6",
      "websocket-driver@<0.7.5": "0.7.5",
      "ws@>=7.0.0 <7.5.11": "7.5.11",
      "ws@>=8.0.0 <8.21.0": "8.21.0",
      "yaml@>=1.0.0 <1.10.3": "1.10.3",
      "yaml@>=2.0.0 <2.8.3": "2.8.3"
    }
  }
}
