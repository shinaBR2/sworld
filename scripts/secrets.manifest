# sworld machine-only secrets — backup/restore manifest
#
# One path per line. These files are gitignored and live ONLY on this machine;
# a lost laptop loses them unless they are backed up (SWO-508).
#
# Path conventions:
#   ~/...           → resolved against $HOME
#   anything else   → resolved against the workspace root ($SWORLD_WORKSPACE,
#                     default ~/Projects/sworld — the folder holding the 3 repos)
#
# This file contains ONLY paths, never secret values — safe to commit.
# NOT backed up here (recreated by CLI login instead): ~/.config/gcloud,
# ~/.config/configstore/firebase-tools.json.

# --- Home-dir credential stores ---
~/.config/linear/credentials.toml
~/.sworld-cli/config.json

# --- Workspace-root files ---
.linear.toml
service-account.json
ocr-only-service-account.json
cli.json
sworld/.claude/settings.local.json

# --- Frontend (sworld) ---
sworld/.env.development.local
sworld/.env.sentry-build-plugin
sworld/packages/core/.env
sworld/apps/main/.env
sworld/apps/main/.env.development.local
sworld/apps/listen/.env
sworld/apps/listen/.env.development.local
sworld/apps/watch/.env
sworld/apps/watch/.env.development.local
sworld/apps/til/.env
sworld/apps/til/.env.development.local
sworld/apps/docs/.env.development.local
sworld/apps/game/.env
sworld/apps/extension/.env

# --- Backend + Hasura ---
sworld-backend/.env
sworld-hasura-v2/.env
sworld-hasura-v2/.env.production
