{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".next/**", "build/**", "public/build/**"],
      "dependsOn": ["^build"],
      "passThroughEnv": ["CODECOV_TOKEN"]
    },
    "build-watch": {
      "dependsOn": ["^build"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["coverage/**"],
      "dependsOn": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "e2e": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "typecheck": {
      "inputs": ["src/**/*.{ts,tsx}", "tsconfig*.json"],
      "dependsOn": []
    }
  }
}
