# Environment variables for the watch app.
# Copy to `.env` (and `.env.development.local` for local dev) and fill each value
# from the source noted below. Every VITE_-prefixed var is bundled into the
# browser — never put a server-only secret here. Values are restored from
# Bitwarden on a fresh machine (see scripts/README.md).

# --- Firebase (console → Project settings → Web app config) ---
VITE_API_KEY=
VITE_APP_ID=
VITE_PROJECT_ID=
VITE_MESSAGING_SENDER_ID=
VITE_STORAGE_BUCKET=
VITE_MEASUREMENT_ID=

# --- Auth0 (dashboard → Application settings) ---
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH_DOMAIN=

# --- Hasura (Hasura Cloud project) ---
VITE_HASURA_DOMAIN=

# --- Rollbar (project → Project Access Tokens) ---
VITE_ROLLBAR_TOKEN=
VITE_ROLLBAR_ENV=

# --- PostHog (project settings) ---
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

# --- Cross-app URLs (static — the deployed app URLs) ---
VITE_MAIN_SITE_URL=
VITE_LISTEN_SITE_URL=
VITE_WATCH_SITE_URL=
VITE_PLAY_SITE_URL=

# --- Misc ---
VITE_EXTENSION_ID=
VITE_USE_EMULATOR_CLOUD_FUNCTIONS=
