    "ui": "workspace:*"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.3",
    "@dotenvx/dotenvx": "^1.75.1",
    "@graphql-codegen/cli": "^5.0.3",
    "@types/chrome": "^0.0.268",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.2",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
