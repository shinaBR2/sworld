{
  "name": "til",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist && rm -f .env*",
    "pre-dev": "cp ../../.env.development.local .env",
    "lint": "biome lint --quit-on-problem .",
    "format": "biome format --write .",
    "dev": "pnpm run pre-dev && vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.16",
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-code-block": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.0.0",
    "@tiptap/markdown": "^3.21.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "core": "workspace:*",
    "html-react-parser": "^5.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "ui": "workspace:*"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.1",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "rollup-plugin-visualizer": "^5.8.3",
    "shiki": "^3.2.1",
    "tsconfig": "workspace:*",
    "vite": "^8.1.2"
  }
}
