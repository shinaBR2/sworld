# Environment for packages/core — read by `pnpm codegen` to introspect Hasura.
# Server-side only (NOT VITE_-prefixed, not shipped to the browser).
# Restored from Bitwarden on a fresh machine (see scripts/README.md).

# --- Hasura (Hasura Cloud project or local http://localhost:8030) ---
HASURA_GRAPHQL_URL=
HASURA_ADMIN_SECRET=

# --- Rollbar (project → Project Access Tokens) ---
ROLLBAR_TOKEN=
ROLLBAR_ENV=
